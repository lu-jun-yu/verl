# Normalize text files to LF to avoid cross-platform line-ending churn.
* text=auto eol=lf

# Keep Windows-native scripts in CRLF if they are added later.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Common binary assets.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.bz2 binary
*.xz binary
*.7z binary
*.pt binary
*.pth binary
*.bin binary
*.onnx binary
*.so binary
*.dll binary
*.dylib binary
